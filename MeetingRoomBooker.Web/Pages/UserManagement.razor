@page "/users"
@using MeetingRoomBooker.Shared.Models
@inject IBookingService BookingService
@inject NavigationManager Navigation

<div class="um-page">
    <div class="um-header um-fade-in">
        <h3 class="um-title">ADMIN CONSOLE // USER MANAGEMENT</h3>
        <div class="um-title-line"></div>
    </div>

    <section class="um-card um-form-card um-fade-in um-delay-1">
        <h4 class="um-card-title">REGISTER NEW PERSONNEL</h4>

        <div class="um-form">
            <input @bind="newName"
                   class="um-input"
                   placeholder="NAME"
                   autocomplete="off" />

            <input @bind="newEmail"
                   class="um-input"
                   placeholder="EMAIL IDENTITY"
                   autocomplete="off" />

            <input @bind="newPassword"
                   type="password"
                   class="um-input"
                   placeholder="ACCESS KEY"
                   autocomplete="new-password" />

            <input @bind="newConfirmPassword"
                   type="password"
                   class="um-input"
                   placeholder="CONFIRM KEY"
                   autocomplete="new-password" />

            <input @bind="newChatworkAccountId"
                   class="um-input"
                   placeholder="CHATWORK ACCOUNT ID (OPTIONAL)"
                   autocomplete="off" />

            <button type="button"
                    class="um-register-button"
                    @onclick="AddUser">
                EXECUTE REGISTRATION
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(msg))
        {
            <div class="um-message">@msg</div>
        }
    </section>

    <section class="um-list" aria-label="Registered personnel">
        @foreach (var user in users)
        {
            <article class="um-row">
                <div class="um-user">
                    <div class="um-user-main">
                        <span class="um-id">ID_@user.Id.ToString("D3")</span>
                        <span class="um-name">@user.Name</span>
                        <span class="um-email">@user.Email</span>
                    </div>

                    <div class="um-chatwork-editor">
                        <span class="um-chatwork-label">CW ACCOUNT ID</span>
                        <input @bind="user.ChatworkAccountId"
                               class="um-account-input"
                               placeholder="NOT SET"
                               autocomplete="off" />
                        <button type="button"
                                class="um-save-button"
                                @onclick="() => SaveChatworkAccountIdAsync(user)">
                            SAVE CW
                        </button>
                    </div>
                </div>

                <div class="um-row-actions">
                    @if (user.Name != "Haru")
                    {
                        <button type="button"
                                class="um-delete-button"
                                @onclick="() => DeleteUser(user.Id)">
                            TERMINATE
                        </button>
                    }
                    else
                    {
                        <span class="um-admin-badge">ADMIN</span>
                    }
                </div>
            </article>
        }
    </section>
</div>

@code {
    private List<UserModel> users = new();
    private string newName = string.Empty;
    private string newEmail = string.Empty;
    private string newPassword = string.Empty;
    private string newConfirmPassword = string.Empty;
    private string newChatworkAccountId = string.Empty;
    private string msg = string.Empty;
    private UserModel? currentUser;

    protected override async Task OnInitializedAsync()
    {
        currentUser = BookingService.GetCurrentUser();

        if (currentUser is null || currentUser.Name != "Haru")
        {
            Navigation.NavigateTo("/");
            return;
        }

        users = await BookingService.GetAllUsersAsync();
    }

    private async Task AddUser()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(newName)
                || string.IsNullOrWhiteSpace(newEmail)
                || string.IsNullOrWhiteSpace(newPassword))
            {
                msg = "ERROR: MISSING FIELDS";
                return;
            }

            if (newPassword != newConfirmPassword)
            {
                msg = "ERROR: KEY MISMATCH";
                return;
            }

            var user = new UserModel
            {
                Name = newName.Trim(),
                Email = newEmail.Trim(),
                Password = newPassword,
                AvatarColor = "#a371f7",
                ChatworkAccountId = NormalizeChatworkAccountId(newChatworkAccountId)
            };

            var registered = await BookingService.RegisterUserAsync(user);

            if (!registered)
            {
                msg = "ERROR: REGISTRATION FAILED";
                return;
            }

            await ReloadUsersAsync();

            newName = string.Empty;
            newEmail = string.Empty;
            newPassword = string.Empty;
            newConfirmPassword = string.Empty;
            newChatworkAccountId = string.Empty;
            msg = "REGISTRATION SUCCESSFUL";
        }
        catch (Exception ex)
        {
            msg = $"ERROR: {ex.Message}";
        }
    }

    private async Task SaveChatworkAccountIdAsync(UserModel user)
    {
        try
        {
            await BookingService.UpdateUserChatworkAccountIdAsync(user.Id, user.ChatworkAccountId);
            await ReloadUsersAsync();
            msg = $"CHATWORK ACCOUNT UPDATED: {user.Name}";
        }
        catch (Exception ex)
        {
            msg = $"ERROR: {ex.Message}";
        }
    }

    private async Task DeleteUser(int id)
    {
        try
        {
            await BookingService.DeleteUserAsync(id);
            await ReloadUsersAsync();
            msg = "USER REMOVED";
        }
        catch (Exception ex)
        {
            msg = $"ERROR: {ex.Message}";
        }
    }

    private async Task ReloadUsersAsync()
    {
        users = await BookingService.GetAllUsersAsync();
    }

    private static string? NormalizeChatworkAccountId(string value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? null
            : value.Trim();
    }
}