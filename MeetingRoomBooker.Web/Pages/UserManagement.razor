@page "/users"
@using MeetingRoomBooker.Shared.Models
@inject IBookingService BookingService
@inject NavigationManager Navigation

<div class="um-page">
    <div class="um-header um-fade-in">
        <h3 class="um-title">ADMIN CONSOLE // USER MANAGEMENT</h3>
        <div class="um-title-line"></div>
    </div>

    <section class="um-card um-form-card um-fade-in um-delay-1">
        <h4 class="um-card-title">REGISTER NEW PERSONNEL</h4>

        <div class="um-form">
            <input @bind="newName"
                   class="um-input"
                   placeholder="NAME"
                   autocomplete="off" />

            <input @bind="newEmail"
                   class="um-input"
                   placeholder="EMAIL IDENTITY"
                   autocomplete="off" />

            <input @bind="newPassword"
                   type="password"
                   class="um-input"
                   placeholder="ACCESS KEY"
                   autocomplete="new-password" />

            <input @bind="newConfirmPassword"
                   type="password"
                   class="um-input"
                   placeholder="CONFIRM KEY"
                   autocomplete="new-password" />

            <button type="button"
                    class="um-register-button"
                    @onclick="AddUser">
                EXECUTE REGISTRATION
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(msg))
        {
            <div class="um-message">@msg</div>
        }
    </section>

    <section class="um-list" aria-label="Registered personnel">
        @foreach (var u in users)
        {
            <article class="um-row">
                <div class="um-user">
                    <span class="um-id">ID_@u.Id.ToString("D3")</span>
                    <span class="um-name">@u.Name</span>
                    <span class="um-email">@u.Email</span>
                </div>

                @if (u.IsAdmin)
                {
                    <span class="um-admin-badge">ADMIN</span>
                }
                else
                {
                    <button type="button"
                            class="um-delete-button"
                            @onclick="() => DeleteUser(u.Id)">
                        TERMINATE
                    </button>
                }
            </article>
        }
    </section>
</div>

@code {
    private List<UserModel> users = new();
    private string newName = string.Empty;
    private string newEmail = string.Empty;
    private string newPassword = string.Empty;
    private string newConfirmPassword = string.Empty;
    private string msg = string.Empty;
    private UserModel? currentUser;

    protected override async Task OnInitializedAsync()
    {
        currentUser = BookingService.GetCurrentUser();

        if (currentUser is null || currentUser.IsAdmin != true)
        {
            Navigation.NavigateTo("/");
            return;
        }

        users = await BookingService.GetAllUsersAsync();
    }

    private async Task AddUser()
    {
        if (string.IsNullOrWhiteSpace(newName) ||
            string.IsNullOrWhiteSpace(newEmail) ||
            string.IsNullOrWhiteSpace(newPassword))
        {
            msg = "ERROR: MISSING FIELDS";
            return;
        }

        if (newPassword != newConfirmPassword)
        {
            msg = "ERROR: KEY MISMATCH";
            return;
        }

        if (users.Any(u => u.Email.Equals(newEmail, StringComparison.OrdinalIgnoreCase)))
        {
            msg = "ERROR: EMAIL ALREADY EXISTS";
            return;
        }

        var success = await BookingService.RegisterUserAsync(new UserModel
        {
            Name = newName.Trim(),
            Email = newEmail.Trim(),
            Password = newPassword,
            IsAdmin = false,
            AvatarColor = "#a371f7"
        });

        if (!success)
        {
            msg = "ERROR: EMAIL ALREADY EXISTS";
            return;
        }

        users = await BookingService.GetAllUsersAsync();

        newName = string.Empty;
        newEmail = string.Empty;
        newPassword = string.Empty;
        newConfirmPassword = string.Empty;
        msg = "REGISTRATION SUCCESSFUL";
    }

    private async Task DeleteUser(int id)
    {
        await BookingService.DeleteUserAsync(id);
        users = await BookingService.GetAllUsersAsync();
    }
}