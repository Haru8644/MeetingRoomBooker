    private sealed class RenderItem
    {
        public ReservationModel? Booking { get; set; }

        public string Style { get; set; } = string.Empty;

        public bool HasConflict { get; set; }
    }

    private sealed class WorkScheduleRenderItem
    {
        public WorkScheduleEntryModel? Entry { get; set; }

        public string Style { get; set; } = string.Empty;
    }

    private sealed class RoomTimelineData
    {
        public List<RenderItem> Items { get; set; } = new();

        public double RowHeight { get; set; }
    }

    private sealed class WorkScheduleTimelineData
    {
        public List<WorkScheduleRenderItem> Items { get; set; } = new();

        public double RowHeight { get; set; }
    }

    private sealed class TimeTick
    {
        public string Label { get; init; } = string.Empty;

        public double Position { get; init; }

        public bool IsFirst { get; init; }
    }

    private readonly List<TimeTick> timelineTicks = CreateTimeTicks();

    private static List<TimeTick> CreateTimeTicks()
    {
        var ticks = new List<TimeTick>();

        for (var hour = 9; hour <= 22; hour++)
        {
            ticks.Add(new TimeTick
            {
                Label = $"{hour}:00",
                Position = GetTimePosition(hour, 0),
                IsFirst = hour == 9
            });
        }

        return ticks;
    }

    private static double GetTimePosition(int hour, int minute)
    {
        const double startMinutes = 9 * 60;
        const double endMinutes = 22 * 60;

        var totalMinutes = (hour * 60d) + minute;
        var clampedMinutes = Math.Clamp(totalMinutes, startMinutes, endMinutes);

        return ((clampedMinutes - startMinutes) / (endMinutes - startMinutes)) * 100d;
    }

    private static double GetDurationWidth(DateTime start, DateTime end)
    {
        var width = GetTimePosition(end.Hour, end.Minute) - GetTimePosition(start.Hour, start.Minute);
        return Math.Max(width, 0.5d);
    }

    private RoomTimelineData GetTimelineRoomData(string room, DateTime date)
    {
        var bookings = GetBookings(date, room);
        var items = new List<RenderItem>();

        if (!bookings.Any())
        {
            return new RoomTimelineData
            {
                Items = items,
                RowHeight = 100
            };
        }

        var clusters = new List<List<ReservationModel>>();
        var current = new List<ReservationModel> { bookings[0] };
        var end = bookings[0].EndTime;

        for (var i = 1; i < bookings.Count; i++)
        {
            if (bookings[i].StartTime < end)
            {
                current.Add(bookings[i]);

                if (bookings[i].EndTime > end)
                {
                    end = bookings[i].EndTime;
                }
            }
            else
            {
                clusters.Add(current);
                current = new List<ReservationModel> { bookings[i] };
                end = bookings[i].EndTime;
            }
        }

        clusters.Add(current);

        var maxLanesInRoom = 0;
        const int LaneHeight = 60;

        foreach (var cluster in clusters)
        {
            var lanes = new List<List<ReservationModel>>();

            foreach (var booking in cluster)
            {
                var placed = false;

                for (var i = 0; i < lanes.Count; i++)
                {
                    if (lanes[i].Last().EndTime <= booking.StartTime)
                    {
                        lanes[i].Add(booking);
                        placed = true;
                        break;
                    }
                }

                if (!placed)
                {
                    lanes.Add(new List<ReservationModel> { booking });
                }
            }

            maxLanesInRoom = Math.Max(maxLanesInRoom, lanes.Count);

            for (var i = 0; i < lanes.Count; i++)
            {
                foreach (var booking in lanes[i])
                {
                    var style =
                        $"left: {GetTimePosition(booking.StartTime.Hour, booking.StartTime.Minute)}%; " +
                        $"width: {GetDurationWidth(booking.StartTime, booking.EndTime)}%; " +
                        $"top: {i * LaneHeight + 5}px; height: {LaneHeight - 4}px; " +
                        "position: absolute; border-radius: 4px; padding: 4px 6px; color: white; " +
                        "overflow: hidden; cursor: pointer; " +
                        $"border: {(IsMyBooking(booking) ? "2px solid #d29922;" : "1px solid rgba(255,255,255,0.2);")} " +
                        "z-index: 10; display: flex; flex-direction: column; justify-content: center;";

                    items.Add(new RenderItem
                    {
                        Booking = booking,
                        HasConflict = HasReservationWarning(booking),
                        Style = style
                    });
                }
            }
        }

        var rowHeight = Math.Max(100, maxLanesInRoom * LaneHeight + 15);

        return new RoomTimelineData
        {
            Items = items,
            RowHeight = rowHeight
        };
    }

    private WorkScheduleTimelineData GetTimelineWorkScheduleData(WorkScheduleSection section, DateTime date)
    {
        var entries = GetWorkSchedules(date, section.Type);
        var items = new List<WorkScheduleRenderItem>();

        if (!entries.Any())
        {
            return new WorkScheduleTimelineData
            {
                Items = items,
                RowHeight = 100
            };
        }

        const int LaneHeight = 58;

        for (var i = 0; i < entries.Count; i++)
        {
            var entry = entries[i];
            var isTimed = entry.Type == WorkScheduleEntryType.ExternalAppointment &&
                          entry.StartTime.HasValue &&
                          entry.EndTime.HasValue;

            var left = isTimed
                ? GetTimePosition(entry.StartTime!.Value.Hour, entry.StartTime.Value.Minute)
                : 0d;

            var width = isTimed
                ? GetDurationWidth(entry.StartTime!.Value, entry.EndTime!.Value)
                : 100d;

            var style =
                $"left: {left}%; width: {width}%; top: {i * LaneHeight + 5}px; height: {LaneHeight - 4}px; " +
                "position: absolute; border-radius: 4px; padding: 4px 6px; color: white; " +
                $"overflow: hidden; cursor: pointer; background: linear-gradient(135deg, rgba(0,0,0,0.72), {section.Color}55); " +
                $"border: {(IsMyWorkSchedule(entry) ? "2px solid #d29922;" : $"1px solid {section.Color};")} " +
                $"box-shadow: 0 0 16px {section.Color}44; " +
                "z-index: 10; display: flex; flex-direction: column; justify-content: center;";

            items.Add(new WorkScheduleRenderItem
            {
                Entry = entry,
                Style = style
            });
        }

        var rowHeight = Math.Max(100, entries.Count * LaneHeight + 15);

        return new WorkScheduleTimelineData
        {
            Items = items,
            RowHeight = rowHeight
        };
    }
