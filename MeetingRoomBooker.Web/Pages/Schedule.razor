@page "/schedule"
@using MeetingRoomBooker.Shared.Models
@using System.Globalization
@inject IBookingService BookingService
@inject WorkScheduleApiService WorkScheduleService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@using Microsoft.Extensions.Logging
@inject ILogger<Schedule> Logger
@implements IDisposable

<style>
    @@media (min-width: 769px) {
        .body-content {
            overflow: hidden !important;
            padding-bottom: 0 !important;
        }

        .content-wrapper {
            padding-bottom: 0 !important;
            height: 100%;
        }
    }
</style>

<div class="schedule-container">
    <div class="sidebar-panel">
        <h3 class="gradient-text title-text">CALENDAR</h3>

        <div class="cyber-card-enhanced control-card">
            <div class="calendar-header">
                <button class="nav-btn" @onclick="PrevMonth">◀</button>
                <div class="current-month-label">@displayMonth.ToString("yyyy年 M月")</div>
                <button class="nav-btn" @onclick="NextMonth">▶</button>
            </div>

            <div class="calendar-grid header-row">
                <div class="week-day">日</div>
                <div class="week-day">月</div>
                <div class="week-day">火</div>
                <div class="week-day">水</div>
                <div class="week-day">木</div>
                <div class="week-day">金</div>
                <div class="week-day">土</div>
            </div>

            <div class="calendar-grid body-rows">
                @foreach (var day in calendarDays)
                {
                    var isSelected = day.Date == selectedDateValue.Date;
                    var isToday = day.Date == DateTime.Today;
                    var isOtherMonth = day.Month != displayMonth.Month;
                    var hasMyBooking = allReservations.Any(r => r.Date.Date == day.Date && IsMyBooking(r));
                    var hasMyWorkSchedule = allWorkSchedules.Any(entry => entry.Date.Date == day.Date && IsMyWorkSchedule(entry));

                    <div class="calendar-cell
                             @(isSelected ? "selected" : "")
                             @(isOtherMonth ? "other-month" : "")
                             @((hasMyBooking || hasMyWorkSchedule) ? "has-my-booking" : "")"
                         @onclick="() => SelectDate(day)">
                        <span class="day-number">@day.Day</span>
                        @if (isToday)
                        {
                            <div class="calendar-today-dot"></div>
                        }
                    </div>
                }
            </div>

            <div class="current-range-text">
                Selected: <span class="selected-date-highlight">@selectedDateValue.ToString("yyyy/MM/dd")</span>
            </div>

            <div class="calendar-quick-actions">
                <button class="timeline-btn today-return-btn" @onclick="ReturnToToday">
                    <span class="oi oi-reload"></span> 今日に戻る
                </button>
            </div>

            <div class="legend-box">
                <div class="legend-item"><span class="legend-color internal"></span>社内</div>
                <div class="legend-item"><span class="legend-color visitor"></span>来客</div>
                <div class="legend-item"><span class="legend-color" style="background: #f0883e;"></span>社外予定</div>
                <div class="legend-item"><span class="legend-color" style="background: #a371f7;"></span>在宅</div>
                <div class="legend-item"><span class="legend-color" style="background: #f85149;"></span>休暇</div>
                <div class="legend-item"><span class="legend-icon my-border-legend"></span>自分/参加</div>
                <div class="legend-item"><span class="legend-icon today-dot-legend"></span>今日</div>
            </div>
        </div>

        <button class="cyber-button-primary pulse-hover" style="width: 100%; margin-top: 20px;" @onclick="GoToReservation">
            <span class="oi oi-pencil"></span> 予約フォームに戻る
        </button>
    </div>

    <div class="main-list-area">
        @if (isLoading)
        {
            <div class="loading-text">Loading...</div>
        }
        else
        {
            <div @key="selectedDateValue" class="fade-in-list">
                @foreach (var date in GetDisplayDates())
                {
                    if (!HasAnyCalendarItem(date))
                    {
                        continue;
                    }

                    <div class="date-group">
                        <div class="sticky-date-header">
                            <div class="date-label-area">
                                <span class="date-year">@date.Year.</span>
                                <span class="date-big">@date.ToString("MM/dd")</span>
                                <span class="date-week">(@date.ToString("ddd"))</span>
                            </div>
                            <button class="timeline-btn" @onclick="() => OpenTimelineModal(date)">
                                <span class="oi oi-bar-chart"></span> Timeline
                            </button>
                        </div>

                        <div class="room-groups">
                            @foreach (var room in roomList)
                            {
                                var bookings = GetBookings(date, room);
                                if (!bookings.Any())
                                {
                                    continue;
                                }

                                <div class="room-row">
                                    <div class="room-label" data-room="@room" style="@BuildRoomLabelStyle(GetRoomColor(room))">@room</div>
                                    <div class="booking-cards">
                                        @foreach (var b in bookings)
                                        {
                                            <div class="booking-card @GetBookingTypeClass(b.Type) @(IsMyBooking(b) ? "my-booking" : "")"
                                                 data-type="@b.Type"
                                                 @onclick="() => ShowDetail(b)">

                                                <div class="type-icon-bg">
                                                    @if (b.Type == "社内")
                                                    {
                                                        <span class="oi oi-briefcase"></span>
                                                    }
                                                    else
                                                    {
                                                        <span class="oi oi-people"></span>
                                                    }
                                                </div>

                                                @if (HasReservationWarning(b))
                                                {
                                                    <div class="warning-icon">⚠</div>
                                                }

                                                <div class="time-badge">@b.StartTime.ToString("HH:mm") - @b.EndTime.ToString("HH:mm")</div>
                                                <div class="card-content">
                                                    <div class="card-title">@GetReservationCardTitle(b)</div>
                                                    <div class="card-desc">@GetReservationCardDetails(b)</div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            @foreach (var scheduleSection in workScheduleSections)
                            {
                                var entries = GetWorkSchedules(date, scheduleSection.Type);
                                if (!entries.Any())
                                {
                                    continue;
                                }

                                <div class="room-row">
                                    <div class="room-label" data-room="@scheduleSection.Label" style="@BuildRoomLabelStyle(scheduleSection.Color)">
                                        @scheduleSection.Label
                                    </div>
                                    <div class="booking-cards">
                                        @foreach (var entry in entries)
                                        {
                                            <div class="booking-card @(IsMyWorkSchedule(entry) ? "my-booking" : "")"
                                                 data-type="@scheduleSection.Label"
                                                 style="@BuildWorkScheduleListCardStyle(scheduleSection.Color)"
                                                 @onclick="() => ShowWorkScheduleDetail(entry)">

                                                <div class="type-icon-bg" style="@BuildColorStyle(scheduleSection.Color)">
                                                    <span class="@scheduleSection.IconClass"></span>
                                                </div>

                                                @if (HasWorkScheduleWarning(entry))
                                                {
                                                    <div class="warning-icon">⚠</div>
                                                }

                                                <div class="time-badge" style="@BuildColorStyle(scheduleSection.Color)">
                                                    @GetWorkScheduleTimeLabel(entry)
                                                </div>
                                                <div class="card-content">
                                                    <div class="card-title">@GetWorkScheduleCardTitle(entry)</div>
                                                    <div class="card-desc">@GetWorkScheduleDetails(entry)</div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="end-of-list">End of list (No more future bookings)</div>
            </div>
        }
    </div>
</div>

@if (selectedBooking != null)
{
    <div class="modal-backdrop" @onclick="CloseDetail" @ontouchmove:stopPropagation="true" style="z-index: 30000 !important;">
        <div class="modal-content cyber-modal-animated" @onclick:stopPropagation="true">
            @if (!isEditing)
            {
                <div class="modal-header">
                    <h3 class="modal-title gradient-text-enhanced" style="background: none !important; -webkit-text-fill-color: transparent !important; background-image: linear-gradient(135deg, #00c6ff, #d53369) !important; -webkit-background-clip: text !important;">
                        @selectedBooking.Name
                    </h3>
                    <button class="close-btn" @onclick="CloseDetail">×</button>
                </div>

                <div class="detail-body">
                    <div class="cyber-detail-row slide-in-right" style="--i:1">
                        <div class="label">日時</div>
                        <div class="value value-text">@selectedBooking.Date.ToString("yyyy/MM/dd")<br />@selectedBooking.StartTime.ToString("HH:mm") - @selectedBooking.EndTime.ToString("HH:mm")</div>
                    </div>
                    <div class="cyber-detail-row slide-in-right" style="--i:2">
                        <div class="label">会議室</div>
                        <div class="value value-text" style="@BuildModalAccentStyle(GetRoomColor(selectedBooking.Room))">@selectedBooking.Room</div>
                    </div>
                    <div class="cyber-detail-row slide-in-right" style="--i:3">
                        <div class="label">区分</div>
                        <div class="value value-text" style="@BuildModalAccentStyle(GetTypeColor(selectedBooking.Type))">@selectedBooking.Type</div>
                    </div>
                    <div class="cyber-detail-row slide-in-right" style="--i:4">
                        <div class="label">目的</div>
                        <div class="value value-text">@selectedBooking.Purpose</div>
                    </div>
                    <div class="cyber-detail-row slide-in-right" style="--i:5">
                        <div class="label">参加者</div>
                        <div class="value value-text">@GetParticipantNames(selectedBooking.ParticipantIds)</div>
                    </div>
                </div>

                <div class="modal-footer fade-in" style="animation-delay: 0.3s; flex-wrap: wrap; gap: 10px;">
                    @if (IsOwner(selectedBooking))
                    {
                        <button class="cyber-button-primary" @onclick="StartEdit">編集</button>

                        @if (IsRecurringReservation(selectedBooking))
                        {
                            <button class="cyber-button-danger" @onclick="() => DeleteBooking(ReservationSeriesScopes.Single)">今回のみ削除</button>
                            <button class="cyber-button-danger" @onclick="() => DeleteBooking(ReservationSeriesScopes.Following)">今回以降削除</button>
                            <button class="cyber-button-danger" @onclick="() => DeleteBooking(ReservationSeriesScopes.All)">全て削除</button>
                        }
                        else
                        {
                            <button class="cyber-button-danger" @onclick="() => DeleteBooking(ReservationSeriesScopes.Single)">削除</button>
                        }
                    }
                    else if (CanJoinReservation(selectedBooking))
                    {
                        <button class="cyber-button-primary" @onclick="ToggleParticipationAsync">参加する</button>
                    }
                    else if (CanLeaveReservation(selectedBooking))
                    {
                        <button class="cyber-button-danger" @onclick="ToggleParticipationAsync">参加を取り消す</button>
                    }

                    <button class="cyber-button-secondary" @onclick="CloseDetail">閉じる</button>
                </div>
            }
            else
            {
                <div class="modal-header">
                    <h3 class="modal-title gradient-text-enhanced" style="background: none !important; -webkit-text-fill-color: transparent !important; background-image: linear-gradient(135deg, #00c6ff, #d53369) !important; -webkit-background-clip: text !important;">
                        予約の編集
                    </h3>
                </div>

                <div class="fluent-stack-scrollable">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="15" Style="padding: 10px;">
                        <div class="fade-in-up" style="--i:1; position: relative; z-index: 80;">
                            <label>予約者名</label>
                            <FluentTextField @bind-Value="editName" ReadOnly="true" Style="width: 100%;" />
                        </div>

                        <div class="fade-in-up" style="--i:2; position: relative; z-index: 70;">
                            <label>利用日</label>
                            <FluentDatePicker @bind-Value="editDate" Style="width: 100%;" />
                        </div>

                        <div class="fade-in-up" style="--i:3; position: relative; z-index: 60;">
                            <label>会議室</label>
                            <div class="selection-group">
                                @foreach (var room in roomList)
                                {
                                    <div class="selection-chip @(editRoom == room ? "active" : "")" @onclick="() => editRoom = room">@room</div>
                                }
                            </div>
                        </div>

                        <div class="fade-in-up" style="--i:4; position: relative; z-index: 50;">
                            <label>区分</label>
                            <div class="selection-group">
                                @foreach (var type in typeList)
                                {
                                    <div class="selection-chip @(editType == type ? "active" : "")" @onclick="() => editType = type">@type</div>
                                }
                            </div>
                        </div>

                        <div class="responsive-grid fade-in-up" style="--i:5; position: relative; z-index: 40;">
                            <div>
                                <label>開始</label>
                                <FluentTimePicker @bind-Value="editStart" @bind-Value:after="OnEditStartChanged" Style="width:100%" />
                            </div>
                            <div>
                                <label>終了</label>
                                <FluentTimePicker @bind-Value="editEnd" Style="width:100%" />
                            </div>
                        </div>

                        <div class="fade-in-up" style="--i:6; position: relative; z-index: 30;">
                            <label>参加メンバー</label>
                            <div class="member-select-box">
                                @if (currentUser != null)
                                {
                                    <div class="participant-item">
                                        <input class="form-check-input" type="checkbox" checked="true" disabled>
                                        <label class="form-check-label" style="display:inline; margin-left:5px;">@($"{currentUser.Name}（予約者本人・固定）")</label>
                                    </div>
                                }

                                @foreach (var user in allUsers)
                                {
                                    if (currentUser != null && user.Id == currentUser.Id)
                                    {
                                        continue;
                                    }

                                    <div class="participant-item">
                                        <input class="form-check-input" type="checkbox" id="edit_user_@user.Id" checked="@(editParticipantIds.Contains(user.Id))" @onchange="@(e => ToggleEditMember(user.Id, e.Value))">
                                        <label class="form-check-label" for="edit_user_@user.Id" style="display:inline; margin-left:5px; cursor:pointer;">@user.Name</label>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="fade-in-up" style="--i:7; position: relative; z-index: 20;">
                            <label>目的</label>
                            <FluentTextField @bind-Value="editPurpose" Style="width: 100%;" />
                        </div>

                        @if (selectedBooking != null && IsRecurringReservation(selectedBooking))
                        {
                            <div class="fade-in-up" style="--i:8; position: relative; z-index: 15; margin-top: 10px; border-top: 1px solid #30363d; padding-top: 10px;">
                                <label>反映範囲</label>
                                <div class="selection-group">
                                    <div class="selection-chip @(editSeriesScope == ReservationSeriesScopes.Single ? "active" : "")" @onclick="() => editSeriesScope = ReservationSeriesScopes.Single">今回のみ</div>
                                    <div class="selection-chip @(editSeriesScope == ReservationSeriesScopes.Following ? "active" : "")" @onclick="() => editSeriesScope = ReservationSeriesScopes.Following">今回以降</div>
                                    <div class="selection-chip @(editSeriesScope == ReservationSeriesScopes.All ? "active" : "")" @onclick="() => editSeriesScope = ReservationSeriesScopes.All">全て</div>
                                </div>
                            </div>
                        }

                        <div class="fade-in-up" style="--i:9; position: relative; z-index: 10; margin-top: 10px; border-top: 1px solid #30363d; padding-top: 10px;">
                            <FluentCheckbox @bind-Value="sendNotification" Label="参加者に変更を通知する" Style="color: #d53369 !important; --neutral-foreground-rest: #d53369 !important;" />
                        </div>
                    </FluentStack>
                </div>

                <div class="modal-footer">
                    <button class="cyber-button-primary" @onclick="SaveEdit">保存</button>
                    <button class="cyber-button-secondary" @onclick="CancelEdit">キャンセル</button>
                </div>
            }
        </div>
    </div>
}

@if (selectedWorkSchedule != null)
{
    var workScheduleSection = GetWorkScheduleSection(selectedWorkSchedule.Type);

    <div class="modal-backdrop" @onclick="CloseWorkScheduleDetail" @ontouchmove:stopPropagation="true" style="z-index: 31000 !important;">
        <div class="modal-content cyber-modal-animated" @onclick:stopPropagation="true">
            @if (!isEditingWorkSchedule)
            {
                <div class="modal-header">
                    <h3 class="modal-title gradient-text-enhanced" style="background: none !important; -webkit-text-fill-color: transparent !important; background-image: linear-gradient(135deg, #00c6ff, #d53369) !important; -webkit-background-clip: text !important;">
                        @selectedWorkSchedule.Title
                    </h3>
                    <button class="close-btn" @onclick="CloseWorkScheduleDetail">×</button>
                </div>

                <div class="detail-body">
                    <div class="cyber-detail-row slide-in-right" style="--i:1">
                        <div class="label">種別</div>
                        <div class="value value-text" style="@BuildModalAccentStyle(workScheduleSection.Color)">@workScheduleSection.Label</div>
                    </div>

                    <div class="cyber-detail-row slide-in-right" style="--i:2">
                        <div class="label">日時</div>
                        <div class="value value-text">@selectedWorkSchedule.Date.ToString("yyyy/MM/dd")<br />@GetWorkScheduleTimeLabel(selectedWorkSchedule)</div>
                    </div>

                    <div class="cyber-detail-row slide-in-right" style="--i:3">
                        <div class="label">内容</div>
                        <div class="value value-text">@selectedWorkSchedule.Title</div>
                    </div>

                    @if (selectedWorkSchedule.Type == WorkScheduleEntryType.Leave)
                    {
                        <div class="cyber-detail-row slide-in-right" style="--i:4">
                            <div class="label">休暇区分</div>
                            <div class="value value-text">@GetLeavePeriodLabel(selectedWorkSchedule.LeavePeriod)</div>
                        </div>
                    }

                    <div class="cyber-detail-row slide-in-right" style="--i:5">
                        <div class="label">参加者 / 対象者</div>
                        <div class="value value-text">@GetWorkScheduleDetails(selectedWorkSchedule)</div>
                    </div>
                </div>

                <div class="modal-footer fade-in" style="animation-delay: 0.3s; flex-wrap: wrap; gap: 10px;">
                    @if (CanManageWorkSchedule(selectedWorkSchedule))
                    {
                        <button class="cyber-button-primary" @onclick="StartWorkScheduleEdit">編集</button>
                        <button class="cyber-button-danger" @onclick="DeleteWorkScheduleAsync">削除</button>
                    }

                    <button class="cyber-button-secondary" @onclick="CloseWorkScheduleDetail">閉じる</button>
                </div>
            }
            else
            {
                <div class="modal-header">
                    <h3 class="modal-title gradient-text-enhanced" style="background: none !important; -webkit-text-fill-color: transparent !important; background-image: linear-gradient(135deg, #00c6ff, #d53369) !important; -webkit-background-clip: text !important;">
                        @workScheduleSection.Label の編集
                    </h3>
                </div>

                <div class="fluent-stack-scrollable">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="15" Style="padding: 10px;">
                        <div class="fade-in-up" style="--i:1; position: relative; z-index: 80;">
                            <label>種別</label>
                            <div style="@BuildModalAccentStyle(workScheduleSection.Color)" class="value-text">@workScheduleSection.Label</div>
                        </div>

                        @if (selectedWorkSchedule.Type == WorkScheduleEntryType.ExternalAppointment)
                        {
                            <div class="fade-in-up" style="--i:2; position: relative; z-index: 70;">
                                <label>内容</label>
                                <FluentTextField @bind-Value="workScheduleEditTitle" Style="width: 100%;" />
                            </div>

                            <div class="fade-in-up" style="--i:3; position: relative; z-index: 60;">
                                <label>日付</label>
                                <FluentDatePicker @bind-Value="workScheduleEditDate" Style="width: 100%;" />
                            </div>

                            <div class="responsive-grid fade-in-up" style="--i:4; position: relative; z-index: 50;">
                                <div>
                                    <label>開始</label>
                                    <FluentTimePicker Value="workScheduleEditStart" ValueChanged="OnWorkScheduleEditStartChanged" Style="width:100%" />
                                </div>
                                <div>
                                    <label>終了</label>
                                    <FluentTimePicker @bind-Value="workScheduleEditEnd" Style="width:100%" />
                                </div>
                            </div>

                            <div class="fade-in-up" style="--i:5; position: relative; z-index: 40;">
                                <label>参加メンバー</label>
                                <div class="member-select-box">
                                    @if (currentUser != null)
                                    {
                                        <div class="participant-item">
                                            <input class="form-check-input" type="checkbox" checked="true" disabled>
                                            <label class="form-check-label" style="display:inline; margin-left:5px;">@($"{currentUser.Name}（自分・固定）")</label>
                                        </div>
                                    }

                                    @foreach (var user in allUsers)
                                    {
                                        if (currentUser != null && user.Id == currentUser.Id)
                                        {
                                            continue;
                                        }

                                        <div class="participant-item">
                                            <input class="form-check-input" type="checkbox" id="work_edit_user_@user.Id" checked="@(workScheduleEditParticipantIds.Contains(user.Id))" @onchange="@(e => ToggleWorkScheduleEditParticipant(user.Id, e.Value))">
                                            <label class="form-check-label" for="work_edit_user_@user.Id" style="display:inline; margin-left:5px; cursor:pointer;">@user.Name</label>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="fade-in-up" style="--i:2; position: relative; z-index: 70;">
                                <label>日付</label>
                                <FluentDatePicker @bind-Value="workScheduleEditDate" Style="width: 100%;" />
                            </div>

                            @if (selectedWorkSchedule.Type == WorkScheduleEntryType.Leave)
                            {
                                <div class="fade-in-up" style="--i:3; position: relative; z-index: 60;">
                                    <label>休暇区分</label>
                                    <div class="selection-group">
                                        @foreach (var option in leavePeriodOptions)
                                        {
                                            <div class="selection-chip @(workScheduleEditLeavePeriod == option.Value ? "active" : "")" @onclick="() => workScheduleEditLeavePeriod = option.Value">@option.Label</div>
                                        }
                                    </div>
                                </div>
                            }

                            <div class="fade-in-up" style="--i:4; position: relative; z-index: 50;">
                                <label>登録対象</label>
                                <div class="value-text" style="padding: 10px 12px; border: 1px solid rgba(48,54,61,0.85); border-radius: 8px; background: rgba(0,0,0,0.18); width: fit-content;">
                                    @(currentUser?.Name ?? "ログインユーザー")
                                </div>
                            </div>
                        }
                    </FluentStack>
                </div>

                <div class="modal-footer">
                    <button class="cyber-button-primary" @onclick="SaveWorkScheduleEditAsync">保存</button>
                    <button class="cyber-button-secondary" @onclick="CancelWorkScheduleEdit">キャンセル</button>
                </div>
            }
        </div>
    </div>
}

@if (timelineDate != null)
{
    <div class="modal-backdrop" @onclick="CloseTimelineModal" @ontouchmove:stopPropagation="true" style="z-index: 20000 !important;">
        <div class="modal-content cyber-modal-animated timeline-modal-wide zoom-in-enter" @onclick:stopPropagation="true" style="height: 90vh;">
            <div class="modal-header">
                <h3 class="modal-title gradient-text-enhanced" style="background: none !important; -webkit-text-fill-color: transparent !important; background-image: linear-gradient(135deg, #00c6ff, #d53369) !important; -webkit-background-clip: text !important;">
                    @timelineDate.Value.ToString("yyyy/MM/dd (ddd)")
                </h3>
                <button class="close-btn" @onclick="CloseTimelineModal">×</button>
            </div>

            <div class="legend-box" style="margin: 0 15px 10px; padding-top: 10px; border-top: none; border-bottom: 1px solid #30363d;">
                <div class="legend-item"><span class="legend-color internal"></span>社内</div>
                <div class="legend-item"><span class="legend-color visitor"></span>来客</div>
                <div class="legend-item"><span class="legend-color" style="background: #f0883e;"></span>社外予定</div>
                <div class="legend-item"><span class="legend-icon my-border-legend"></span>自分</div>
                <div class="legend-item"><span class="legend-icon warning">⚠</span>重複</div>
            </div>

            <div class="detail-body" style="padding: 0; overflow: auto; flex-grow: 1;">
                <div class="timeline-container">
                    <div class="timeline-header">
                        <div class="header-spacer sticky-element"></div>
                        <div class="time-scale">
                            @foreach (var tick in timelineTicks)
                            {
                                <div class="time-mark @(tick.IsFirst ? "first-tick" : "")" style="@BuildTimelinePositionStyle(tick.Position)">@tick.Label</div>
                            }
                        </div>
                    </div>

                    @foreach (var room in roomList)
                    {
                        var roomData = GetTimelineRoomData(room, timelineDate.Value);

                        <div class="timeline-row" style="@BuildTimelineRowStyle(roomData.RowHeight)">
                            <div class="room-label-tl sticky-element" style="@BuildTimelineRoomLabelStyle(GetRoomColor(room), roomData.RowHeight)">@room</div>
                            <div class="timeline-track" style="@BuildTimelineRowStyle(roomData.RowHeight)">
                                @foreach (var tick in timelineTicks)
                                {
                                    <div class="grid-line" style="@BuildTimelinePositionStyle(tick.Position)"></div>
                                }

                                @foreach (var item in roomData.Items)
                                {
                                    <div class="booking-block @GetBookingTypeClass(item.Booking!.Type) @(IsMyBooking(item.Booking!) ? "my-booking" : "")"
                                         data-type="@item.Booking!.Type"
                                         style="@item.Style"
                                         @onclick="() => ShowDetail(item.Booking!)">
                                        @if (item.HasConflict)
                                        {
                                            <div class="warning-icon">⚠</div>
                                        }
                                        <div class="block-content">
                                            <div class="block-text name">@GetReservationCardTitle(item.Booking!)</div>
                                            <div class="block-text purpose">@GetReservationCardDetails(item.Booking!)</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    @foreach (var scheduleSection in GetTimelineWorkScheduleSections())
                    {
                        var workScheduleData = GetTimelineWorkScheduleData(scheduleSection, timelineDate.Value);
                        if (!workScheduleData.Items.Any())
                        {
                            continue;
                        }

                        <div class="timeline-row" style="@BuildTimelineRowStyle(workScheduleData.RowHeight)">
                            <div class="room-label-tl sticky-element" style="@BuildTimelineRoomLabelStyle(scheduleSection.Color, workScheduleData.RowHeight)">@scheduleSection.Label</div>
                            <div class="timeline-track" style="@BuildTimelineRowStyle(workScheduleData.RowHeight)">
                                @foreach (var tick in timelineTicks)
                                {
                                    <div class="grid-line" style="@BuildTimelinePositionStyle(tick.Position)"></div>
                                }

                                @foreach (var item in workScheduleData.Items)
                                {
                                    <div class="booking-block @(IsMyWorkSchedule(item.Entry!) ? "my-booking" : "")"
                                         data-type="@scheduleSection.Label"
                                         style="@item.Style"
                                         @onclick="() => ShowWorkScheduleDetail(item.Entry!)">
                                        @if (HasWorkScheduleWarning(item.Entry!))
                                        {
                                            <div class="warning-icon">⚠</div>
                                        }

                                        <div class="block-content">
                                            <div class="block-text name">@GetWorkScheduleCardTitle(item.Entry!)</div>
                                            <div class="block-text purpose">@GetWorkScheduleDetails(item.Entry!)</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="modal-footer">
                <button class="cyber-button-secondary" @onclick="CloseTimelineModal">閉じる</button>
            </div>
        </div>
    </div>
}

