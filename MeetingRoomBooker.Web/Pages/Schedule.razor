    private void StartEdit()
    {
        if (selectedBooking == null)
        {
            return;
        }

        editingOriginalReservation = CloneReservation(selectedBooking);
        editName = selectedBooking.Name;
        editRoom = selectedBooking.Room;
        editType = selectedBooking.Type;
        editPurpose = selectedBooking.Purpose;
        editDate = selectedBooking.Date;
        editStart = selectedBooking.StartTime;
        editEnd = selectedBooking.EndTime;
        editParticipantIds = new List<int>((selectedBooking.ParticipantIds ?? new List<int>()).Where(id => currentUser == null || id != currentUser.Id));
        sendNotification = true;
        editSeriesScope = ReservationSeriesScopes.Single;
        isEditing = true;
    }

    private void CancelEdit()
    {
        isEditing = false;
        editingOriginalReservation = null;
        editSeriesScope = ReservationSeriesScopes.Single;
    }

    private void ToggleEditMember(int userId, object? isChecked)
    {
        if ((bool)(isChecked ?? false))
        {
            if (!editParticipantIds.Contains(userId))
            {
                editParticipantIds.Add(userId);
            }
        }
        else
        {
            editParticipantIds.Remove(userId);
        }
    }

    private async Task SaveEdit()
    {
        if (selectedBooking == null || editingOriginalReservation == null)
        {
            return;
        }

        var reservationId = selectedBooking.Id;
        var updatedReservation = CloneReservation(selectedBooking);

        updatedReservation.Name = editName;
        updatedReservation.Room = editRoom;
        updatedReservation.Type = editType;
        updatedReservation.Purpose = editPurpose;

        if (editDate.HasValue)
        {
            updatedReservation.Date = editDate.Value.Date;
        }

        if (editStart.HasValue)
        {
            updatedReservation.StartTime = updatedReservation.Date.Date + editStart.Value.TimeOfDay;
        }

        if (editEnd.HasValue)
        {
            updatedReservation.EndTime = updatedReservation.Date.Date + editEnd.Value.TimeOfDay;
        }

        if (updatedReservation.EndTime <= updatedReservation.StartTime)
        {
            await JSRuntime.InvokeVoidAsync("alert", "終了時刻は開始時刻より後にしてください。");
            return;
        }

        updatedReservation.ParticipantIds = BuildEditParticipantIds();

        var participantConflicts = FindReservationExternalAppointmentParticipantConflicts(updatedReservation);
        if (participantConflicts.Count > 0)
        {
            var confirmed = await JSRuntime.InvokeAsync<bool>(
                "confirm",
                BuildReservationParticipantConflictConfirmationMessage(participantConflicts));

            if (!confirmed)
            {
                return;
            }
        }

        try
        {
            if (IsRecurringReservation(selectedBooking) && editSeriesScope != ReservationSeriesScopes.Single)
            {
                await BookingService.UpdateRecurringReservationAsync(editingOriginalReservation, updatedReservation, sendNotification, editSeriesScope);
            }
            else
            {
                await BookingService.UpdateReservationAsync(updatedReservation, sendNotification);
            }

            isEditing = false;
            editingOriginalReservation = null;
            editSeriesScope = ReservationSeriesScopes.Single;

            await LoadData();

            selectedBooking = allReservations.FirstOrDefault(r => r.Id == reservationId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to update reservation. reservationId={ReservationId}, currentUserId={UserId}", reservationId, currentUser?.Id);
            await JSRuntime.InvokeVoidAsync("alert", "予約の更新に失敗しました。会議室や参加者の予定が重複していないか確認してください。");
        }
    }

    private async Task DeleteBooking(string scope)
    {
        if (selectedBooking == null)
        {
            return;
        }

        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", GetDeleteConfirmationMessage(scope, selectedBooking));
        if (!confirmed)
        {
            return;
        }

        if (IsRecurringReservation(selectedBooking) && scope != ReservationSeriesScopes.Single)
        {
            await BookingService.RemoveRecurringReservationAsync(selectedBooking, scope);
        }
        else
        {
            await BookingService.RemoveReservationAsync(selectedBooking);
        }

        selectedBooking = null;

        await LoadData();
    }

    private async Task ToggleParticipationAsync()
    {
        if (selectedBooking == null)
        {
            return;
        }

        var reservationId = selectedBooking.Id;

        if (CanJoinReservation(selectedBooking))
        {
            await BookingService.JoinReservationAsync(selectedBooking.Id);
        }
        else if (CanLeaveReservation(selectedBooking))
        {
            var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "この予約への参加を取り消しますか？");
            if (!confirmed)
            {
                return;
            }

            await BookingService.LeaveReservationAsync(selectedBooking.Id);
        }

        await LoadData();

        selectedBooking = allReservations.FirstOrDefault(r => r.Id == reservationId);
    }

    private bool CanJoinReservation(ReservationModel reservation)
    {
        return currentUser != null
            && !IsOwner(reservation)
            && !(reservation.ParticipantIds?.Contains(currentUser.Id) ?? false);
    }

    private bool CanLeaveReservation(ReservationModel reservation)
    {
        return currentUser != null
            && !IsOwner(reservation)
            && (reservation.ParticipantIds?.Contains(currentUser.Id) ?? false);
    }

    private static bool IsRecurringReservation(ReservationModel reservation)
    {
        return !string.IsNullOrWhiteSpace(reservation.RepeatType)
            && reservation.RepeatType != "しない"
            && reservation.RepeatUntil.HasValue;
    }

    private List<int> BuildEditParticipantIds()
    {
        var participantIds = editParticipantIds
            .Where(id => id > 0)
            .Distinct()
            .ToHashSet();

        if (currentUser != null)
        {
            participantIds.Add(currentUser.Id);
        }

        return participantIds.ToList();
    }

    private static string GetDeleteConfirmationMessage(string scope, ReservationModel reservation)
    {
        if (!IsRecurringReservation(reservation) || scope == ReservationSeriesScopes.Single)
        {
            return "削除しますか？";
        }

        return scope == ReservationSeriesScopes.Following
            ? "この予約を今回以降まとめて削除しますか？"
            : "この繰り返し予約をすべて削除しますか？";
    }

    private static ReservationModel CloneReservation(ReservationModel reservation)
    {
        return new ReservationModel
        {
            Id = reservation.Id,
            UserId = reservation.UserId,
            Name = reservation.Name,
            Room = reservation.Room,
            NumberOfPeople = reservation.NumberOfPeople,
            Type = reservation.Type,
            Purpose = reservation.Purpose,
            Date = reservation.Date,
            StartTime = reservation.StartTime,
            EndTime = reservation.EndTime,
            ParticipantIds = new List<int>(reservation.ParticipantIds ?? new List<int>()),
            Participants = reservation.Participants,
            RepeatType = reservation.RepeatType,
            RepeatUntil = reservation.RepeatUntil
        };
    }

