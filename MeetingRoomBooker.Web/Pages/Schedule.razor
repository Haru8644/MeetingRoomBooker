    private void ResetWorkScheduleEditState()
    {
        workScheduleEditTitle = string.Empty;
        workScheduleEditDate = null;
        workScheduleEditStart = null;
        workScheduleEditEnd = null;
        workScheduleEditLeavePeriod = LeavePeriod.FullDay;
        workScheduleEditParticipantIds = new HashSet<int>();
    }

    private void OnWorkScheduleEditStartChanged(DateTime? newTime)
    {
        workScheduleEditStart = newTime;

        if (workScheduleEditStart.HasValue)
        {
            workScheduleEditEnd = workScheduleEditStart.Value.AddHours(1);
        }
    }

    private void ToggleWorkScheduleEditParticipant(int userId, object? isChecked)
    {
        if ((bool)(isChecked ?? false))
        {
            workScheduleEditParticipantIds.Add(userId);
        }
        else
        {
            workScheduleEditParticipantIds.Remove(userId);
        }
    }

    private async Task SaveWorkScheduleEditAsync()
    {
        if (selectedWorkSchedule == null)
        {
            return;
        }

        if (workScheduleEditDate == null)
        {
            await JSRuntime.InvokeVoidAsync("alert", "日付を入力してください。");
            return;
        }

        var request = new UpdateWorkScheduleEntryRequest
        {
            Type = selectedWorkSchedule.Type,
            Date = workScheduleEditDate.Value.Date,
            ParticipantIds = selectedWorkSchedule.Type == WorkScheduleEntryType.ExternalAppointment
                ? BuildWorkScheduleEditParticipantIds()
                : BuildCurrentUserOnlyParticipantIds()
        };

        if (selectedWorkSchedule.Type == WorkScheduleEntryType.ExternalAppointment)
        {
            if (string.IsNullOrWhiteSpace(workScheduleEditTitle))
            {
                await JSRuntime.InvokeVoidAsync("alert", "社外予定の内容を入力してください。");
                return;
            }

            if (workScheduleEditStart == null || workScheduleEditEnd == null)
            {
                await JSRuntime.InvokeVoidAsync("alert", "開始時刻と終了時刻を入力してください。");
                return;
            }

            var start = workScheduleEditDate.Value.Date + workScheduleEditStart.Value.TimeOfDay;
            var end = workScheduleEditDate.Value.Date + workScheduleEditEnd.Value.TimeOfDay;

            if (end <= start)
            {
                await JSRuntime.InvokeVoidAsync("alert", "終了時刻は開始時刻より後にしてください。");
                return;
            }

            var participantConflicts = FindExternalAppointmentParticipantConflicts(
                workScheduleEditTitle,
                workScheduleEditDate.Value.Date,
                start,
                end,
                request.ParticipantIds,
                selectedWorkSchedule.Id);

            if (participantConflicts.Count > 0)
            {
                var confirmed = await JSRuntime.InvokeAsync<bool>(
                    "confirm",
                    BuildParticipantConflictConfirmationMessage(participantConflicts));

                if (!confirmed)
                {
                    return;
                }
            }

            request.Title = workScheduleEditTitle;
            request.StartTime = start;
            request.EndTime = end;
            request.LeavePeriod = LeavePeriod.None;
        }
        else if (selectedWorkSchedule.Type == WorkScheduleEntryType.WorkFromHome)
        {
            request.Title = "在宅";
            request.StartTime = null;
            request.EndTime = null;
            request.LeavePeriod = LeavePeriod.None;
        }
        else
        {
            request.Title = "休暇";
            request.StartTime = null;
            request.EndTime = null;
            request.LeavePeriod = workScheduleEditLeavePeriod;
        }

        var scheduleId = selectedWorkSchedule.Id;

        try
        {
            await WorkScheduleService.UpdateEntryAsync(scheduleId, request);

            isEditingWorkSchedule = false;
            ResetWorkScheduleEditState();

            await LoadData();

            selectedWorkSchedule = allWorkSchedules.FirstOrDefault(entry => entry.Id == scheduleId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to update work schedule entry. entryId={EntryId}", scheduleId);
            await JSRuntime.InvokeVoidAsync("alert", "勤務予定の更新に失敗しました。時間をおいて再度お試しください。");
        }
    }

    private async Task DeleteWorkScheduleAsync()
    {
        if (selectedWorkSchedule == null)
        {
            return;
        }

        var confirmed = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            $"{GetWorkScheduleSection(selectedWorkSchedule.Type).Label}を削除しますか？");

        if (!confirmed)
        {
            return;
        }

        var scheduleId = selectedWorkSchedule.Id;

        try
        {
            await WorkScheduleService.DeleteEntryAsync(scheduleId);
            selectedWorkSchedule = null;
            isEditingWorkSchedule = false;
            ResetWorkScheduleEditState();

            await LoadData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete work schedule entry. entryId={EntryId}", scheduleId);
            await JSRuntime.InvokeVoidAsync("alert", "勤務予定の削除に失敗しました。時間をおいて再度お試しください。");
        }
    }

    private List<int> BuildWorkScheduleEditParticipantIds()
    {
        var participantIds = workScheduleEditParticipantIds
            .Where(id => id > 0)
            .Distinct()
            .ToHashSet();

        if (currentUser != null)
        {
            participantIds.Add(currentUser.Id);
        }

        return participantIds.ToList();
    }

    private List<int> BuildCurrentUserOnlyParticipantIds()
    {
        return currentUser == null
            ? new List<int>()
            : new List<int> { currentUser.Id };
    }

    private List<ParticipantScheduleConflict> FindExternalAppointmentParticipantConflicts(
        string requestedTitle,
        DateTime requestedDate,
        DateTime requestedStart,
        DateTime requestedEnd,
        IReadOnlyCollection<int> requestedParticipantIds,
        int ignoredWorkScheduleId)
    {
        var result = new List<ParticipantScheduleConflict>();

        foreach (var existingReservation in allReservations)
        {
            if (existingReservation.Date.Date != requestedDate.Date ||
                !TimesOverlap(requestedStart, requestedEnd, existingReservation.StartTime, existingReservation.EndTime))
            {
                continue;
            }

            var existingParticipantIds = GetReservationParticipantIds(existingReservation);
            var duplicatedParticipantIds = requestedParticipantIds.Intersect(existingParticipantIds).Distinct();

            foreach (var participantId in duplicatedParticipantIds)
            {
                result.Add(new ParticipantScheduleConflict(
                    requestedDate.Date,
                    requestedStart,
                    requestedEnd,
                    GetParticipantName(participantId),
                    requestedTitle,
                    "会議室予約",
                    GetReservationTitle(existingReservation),
                    existingReservation.StartTime,
                    existingReservation.EndTime));
            }
        }

        foreach (var existingSchedule in allWorkSchedules)
        {
            if (existingSchedule.Id == ignoredWorkScheduleId ||
                existingSchedule.Type != WorkScheduleEntryType.ExternalAppointment ||
                !existingSchedule.StartTime.HasValue ||
                !existingSchedule.EndTime.HasValue ||
                existingSchedule.Date.Date != requestedDate.Date ||
                !TimesOverlap(requestedStart, requestedEnd, existingSchedule.StartTime.Value, existingSchedule.EndTime.Value))
            {
                continue;
            }

            var existingParticipantIds = GetWorkScheduleParticipantIds(existingSchedule);
            var duplicatedParticipantIds = requestedParticipantIds.Intersect(existingParticipantIds).Distinct();

            foreach (var participantId in duplicatedParticipantIds)
            {
                result.Add(new ParticipantScheduleConflict(
                    requestedDate.Date,
                    requestedStart,
                    requestedEnd,
                    GetParticipantName(participantId),
                    requestedTitle,
                    "社外予定",
                    existingSchedule.Title,
                    existingSchedule.StartTime.Value,
                    existingSchedule.EndTime.Value));
            }
        }

        return result;
    }

    private List<ParticipantScheduleConflict> FindReservationExternalAppointmentParticipantConflicts(ReservationModel requestedReservation)
    {
        var result = new List<ParticipantScheduleConflict>();
        var requestedParticipantIds = GetReservationParticipantIds(requestedReservation);

        if (requestedParticipantIds.Count == 0)
        {
            return result;
        }

        var requestedTitle = GetReservationTitle(requestedReservation);

        foreach (var existingSchedule in allWorkSchedules)
        {
            if (existingSchedule.Type != WorkScheduleEntryType.ExternalAppointment ||
                !existingSchedule.StartTime.HasValue ||
                !existingSchedule.EndTime.HasValue ||
                existingSchedule.Date.Date != requestedReservation.Date.Date ||
                !TimesOverlap(
                    requestedReservation.StartTime,
                    requestedReservation.EndTime,
                    existingSchedule.StartTime.Value,
                    existingSchedule.EndTime.Value))
            {
                continue;
            }

            var existingParticipantIds = GetWorkScheduleParticipantIds(existingSchedule);
            var duplicatedParticipantIds = requestedParticipantIds
                .Intersect(existingParticipantIds)
                .Distinct();

            foreach (var participantId in duplicatedParticipantIds)
            {
                result.Add(new ParticipantScheduleConflict(
                    requestedReservation.Date.Date,
                    requestedReservation.StartTime,
                    requestedReservation.EndTime,
                    GetParticipantName(participantId),
                    requestedTitle,
                    "社外予定",
                    existingSchedule.Title,
                    existingSchedule.StartTime.Value,
                    existingSchedule.EndTime.Value));
            }
        }

        return result;
    }

    private static string BuildReservationParticipantConflictConfirmationMessage(
        IReadOnlyCollection<ParticipantScheduleConflict> participantConflicts)
    {
        var lines = new List<string>
        {
            $"{participantConflicts.Count}件の参加者予定が重複しています。",
            "それでも保存しますか？",
            string.Empty,
            "重複内容:"
        };

        foreach (var conflict in participantConflicts.Take(8))
        {
            lines.Add(
                $"・{conflict.Date:yyyy/MM/dd} {conflict.ParticipantName}さん: {conflict.RequestedTitle} ({conflict.RequestedStart:HH:mm}〜{conflict.RequestedEnd:HH:mm}) / 既存{conflict.ExistingKind}: {conflict.ExistingTitle} ({conflict.ExistingStart:HH:mm}〜{conflict.ExistingEnd:HH:mm})");
        }

        if (participantConflicts.Count > 8)
        {
            lines.Add($"ほか {participantConflicts.Count - 8}件");
        }

        return string.Join("\n", lines);
    }

    private HashSet<int> GetReservationParticipantIds(ReservationModel reservation)
    {
        var participantIds = new HashSet<int>();

        if (reservation.UserId > 0)
        {
            participantIds.Add(reservation.UserId);
        }

        foreach (var participantId in reservation.ParticipantIds ?? new List<int>())
        {
            if (participantId > 0)
            {
                participantIds.Add(participantId);
            }
        }

        return participantIds;
    }

    private static HashSet<int> GetWorkScheduleParticipantIds(WorkScheduleEntryModel schedule)
    {
        return (schedule.ParticipantIds ?? new List<int>())
            .Where(id => id > 0)
            .Distinct()
            .ToHashSet();
    }

    private string GetParticipantName(int userId)
    {
        if (currentUser != null && currentUser.Id == userId)
        {
            return currentUser.Name;
        }

        var user = allUsers.FirstOrDefault(u => u.Id == userId);
        return user?.Name ?? $"ユーザーID:{userId}";
    }

    private static string GetReservationTitle(ReservationModel reservation)
    {
        if (!string.IsNullOrWhiteSpace(reservation.Purpose))
        {
            return reservation.Purpose;
        }

        if (!string.IsNullOrWhiteSpace(reservation.Name))
        {
            return reservation.Name;
        }

        return $"{reservation.Room}予約";
    }

    private static bool TimesOverlap(DateTime start1, DateTime end1, DateTime start2, DateTime end2)
    {
        return start1 < end2 && end1 > start2;
    }

