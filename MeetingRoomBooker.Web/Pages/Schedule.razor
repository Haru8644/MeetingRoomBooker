    private void StartWorkScheduleEdit()
    {
        if (selectedWorkSchedule == null)
        {
            return;
        }

        workScheduleEditTitle = selectedWorkSchedule.Title;
        workScheduleEditDate = selectedWorkSchedule.Date;
        workScheduleEditStart = selectedWorkSchedule.StartTime ?? selectedWorkSchedule.Date.Date.AddHours(10);
        workScheduleEditEnd = selectedWorkSchedule.EndTime ?? selectedWorkSchedule.Date.Date.AddHours(11);
        workScheduleEditLeavePeriod = selectedWorkSchedule.LeavePeriod == LeavePeriod.None
            ? LeavePeriod.FullDay
            : selectedWorkSchedule.LeavePeriod;

        workScheduleEditParticipantIds = (selectedWorkSchedule.ParticipantIds ?? new List<int>())
            .Where(id => currentUser == null || id != currentUser.Id)
            .ToHashSet();

        isEditingWorkSchedule = true;
    }

    private void CancelWorkScheduleEdit()
    {
