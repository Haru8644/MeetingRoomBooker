    private bool HasRoomConflict(ReservationModel target)
    {
        return allReservations.Any(existing =>
            existing.Id != target.Id &&
            existing.Room == target.Room &&
            existing.Date.Date == target.Date.Date &&
            existing.StartTime < target.EndTime &&
            existing.EndTime > target.StartTime);
    }

    private bool HasReservationExternalAppointmentParticipantConflict(ReservationModel target)
    {
        var targetParticipantIds = GetReservationParticipantIds(target);

        if (targetParticipantIds.Count == 0)
        {
            return false;
        }

        return allWorkSchedules.Any(existingSchedule =>
            existingSchedule.Type == WorkScheduleEntryType.ExternalAppointment &&
            existingSchedule.StartTime.HasValue &&
            existingSchedule.EndTime.HasValue &&
            existingSchedule.Date.Date == target.Date.Date &&
            TimesOverlap(target.StartTime, target.EndTime, existingSchedule.StartTime.Value, existingSchedule.EndTime.Value) &&
            targetParticipantIds.Overlaps(GetWorkScheduleParticipantIds(existingSchedule)));
    }

    private bool HasWorkScheduleWarning(WorkScheduleEntryModel target)
    {
        if (target.Type != WorkScheduleEntryType.ExternalAppointment ||
            !target.StartTime.HasValue ||
            !target.EndTime.HasValue)
        {
            return false;
        }

        return HasExternalAppointmentReservationParticipantConflict(target) ||
               HasExternalAppointmentScheduleParticipantConflict(target);
    }

    private bool HasExternalAppointmentReservationParticipantConflict(WorkScheduleEntryModel target)
    {
        var targetParticipantIds = GetWorkScheduleParticipantIds(target);

        if (targetParticipantIds.Count == 0)
        {
            return false;
        }

        return allReservations.Any(existingReservation =>
            existingReservation.Date.Date == target.Date.Date &&
            TimesOverlap(target.StartTime!.Value, target.EndTime!.Value, existingReservation.StartTime, existingReservation.EndTime) &&
            targetParticipantIds.Overlaps(GetReservationParticipantIds(existingReservation)));
    }

    private bool HasExternalAppointmentScheduleParticipantConflict(WorkScheduleEntryModel target)
    {
        var targetParticipantIds = GetWorkScheduleParticipantIds(target);

        if (targetParticipantIds.Count == 0)
        {
            return false;
        }

        return allWorkSchedules.Any(existingSchedule =>
            existingSchedule.Id != target.Id &&
            existingSchedule.Type == WorkScheduleEntryType.ExternalAppointment &&
            existingSchedule.StartTime.HasValue &&
            existingSchedule.EndTime.HasValue &&
            existingSchedule.Date.Date == target.Date.Date &&
            TimesOverlap(target.StartTime!.Value, target.EndTime!.Value, existingSchedule.StartTime.Value, existingSchedule.EndTime.Value) &&
            targetParticipantIds.Overlaps(GetWorkScheduleParticipantIds(existingSchedule)));
