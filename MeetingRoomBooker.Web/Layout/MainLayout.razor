@inherits LayoutComponentBase
@using Microsoft.FluentUI.AspNetCore.Components
@inject ThemeService ThemeService
@implements IDisposable

<FluentDesignTheme />
<FluentToastProvider />
<FluentDialogProvider />
<FluentTooltipProvider />
<FluentMessageBarProvider />
<FluentMenuProvider />

<div class="layout-shell">
    <FluentLayout data-theme="@ThemeService.CurrentTheme">
        <div class="cyber-grid-bg"></div>
        <div class="colorful-bg"></div>

        <div class="cyber-side-decoration left outer"></div>
        <div class="cyber-side-decoration right outer"></div>
        <div class="cyber-side-decoration left inner"></div>
        <div class="cyber-side-decoration right inner"></div>

        <FluentHeader Class="cyber-header-enhanced">
            <div class="header-content">
                <span class="oi oi-aperture header-icon pulse-icon"></span>
                <h3 class="gradient-text-enhanced header-title">MeetingRoomBooker</h3>
            </div>
        </FluentHeader>

        <div class="layout-container">
            <div class="desktop-sidebar">
                <div class="sidebar-cyber-effect"></div>
                <NavMenu IsMobile="false" />
            </div>

            <main class="body-content">
                <div class="content-wrapper">
                    @Body
                </div>
            </main>
        </div>

        <div class="mobile-bottom-nav">
            <NavMenu IsMobile="true" />
        </div>

        <FluentFooter Class="desktop-footer">
            Copyright © 2025 Haru - Cybernetics Division
        </FluentFooter>
    </FluentLayout>
</div>

@code {
    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += HandleThemeChanged;
    }

    private void HandleThemeChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= HandleThemeChanged;
    }
}
