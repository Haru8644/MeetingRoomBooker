@using MeetingRoomBooker.Shared.Models
@inject IBookingService BookingService
@inject NavigationManager Navigation
@using Microsoft.Extensions.Logging
@inject ILogger<NavMenu> Logger
@implements IDisposable

<div class="nav-menu-shell @(IsMobile ? "mobile-nav-container" : "desktop-nav-container")">
    <nav class="@(IsMobile ? "mobile-nav" : "flex-column desktop-nav")">
        <NavLink class="@NavLinkClass" href="" Match="NavLinkMatch.All">
            <span class="oi oi-home icon"></span><span class="label">ホーム</span>
        </NavLink>

        @if (currentUser != null)
        {
            <NavLink class="@NavLinkClass" href="reservation">
                <span class="oi oi-plus icon"></span><span class="label">予約</span>
            </NavLink>
            <NavLink class="@NavLinkClass" href="schedule">
                <span class="oi oi-calendar icon"></span><span class="label">カレンダー</span>
            </NavLink>

            <div class="@NotificationWrapperClass">
                <NavLink class="@NavLinkClass" href="notifications">
                    <span class="oi oi-bell icon"></span>
                    <span class="label notification-label">
                        通知
                        @if (unreadCount > 0)
                        {
                            <span class="inline-badge">@unreadCount</span>
                        }
                    </span>
                </NavLink>
            </div>

            @if (currentUser.IsAdmin)
            {
                <NavLink class="@NavLinkClass" href="users">
                    <span class="oi oi-people icon"></span><span class="label">管理</span>
                </NavLink>
            }

            <NavLink class="@NavLinkClass" href="settings">
                <span class="oi oi-cog icon"></span><span class="label">設定</span>
            </NavLink>

            @if (!IsMobile)
            {
                <div class="nav-separator"></div>
            }

            <div class="@ProfileSectionClass" @onclick="ToggleProfileMenu">
                @if (IsMobile)
                {
                    <span class="oi oi-person icon @(showMobileProfile ? "active-profile" : "")"></span>
                    <span class="label">マイページ</span>
                }
                else
                {
                    <div class="user-profile-content">
                        <div class="user-avatar" style="@BuildAvatarStyle(currentUser)">
                            @GetUserInitial(currentUser)<span class="status-dot"></span>
                        </div>
                        <span class="user-name">@currentUser.Name</span>
                    </div>
                    <div class="logout-link" @onclick="LogoutAsync"><span>(Logout)</span></div>
                }
            </div>
        }
        else
        {
            <NavLink class="@NavLinkClass" href="settings">
                <span class="oi oi-cog icon"></span><span class="label">設定</span>
            </NavLink>
            <NavLink class="@NavLinkClass" href="login">
                <span class="oi oi-account-login icon"></span><span class="label">ログイン</span>
            </NavLink>
        }
    </nav>
</div>

@if (IsMobile && showMobileProfile && currentUser != null)
{
    <div class="mobile-profile-menu cyber-card">
        <div class="user-profile-content mb-3">
            <div class="user-avatar" style="@BuildAvatarStyle(currentUser)">
                @GetUserInitial(currentUser)<span class="status-dot"></span>
            </div>
            <span class="user-name">@currentUser.Name</span>
        </div>
        <button class="cyber-button-primary w-100 mobile-logout" @onclick="LogoutAsync">ログアウト</button>
        <button class="close-btn-mobile" @onclick="CloseProfileMenu">×</button>
    </div>
    <div class="mobile-menu-backdrop" @onclick="CloseProfileMenu"></div>
}

@code {
    [Parameter]
    public bool IsMobile { get; set; }
    private UserModel? currentUser;
    private int unreadCount;
    private bool showMobileProfile;

    private string NavLinkClass => IsMobile ? "mobile-nav-link" : "nav-link desktop-nav-link";

    private string NotificationWrapperClass =>
        IsMobile ? "notification-item-wrapper mobile-nav-item" : "notification-item-wrapper";

    private string ProfileSectionClass =>
        IsMobile ? "mobile-nav-item profile-tab" : "user-profile-item px-3";

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        BookingService.OnChange += HandleBookingServiceChanged;
    }

    private async void HandleBookingServiceChanged()
    {
        try
        {
            await LoadDataAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to refresh NavMenu after a booking state change.");
        }
    }

    private async Task LoadDataAsync()
    {
        currentUser = BookingService.GetCurrentUser();
        unreadCount = 0;

        if (currentUser is null)
        {
            return;
        }

        try
        {
            var notifications = await BookingService.GetNotificationsAsync(currentUser.Id);
            unreadCount = notifications.Count(notification => !notification.IsRead);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load notifications for NavMenu. userId={UserId}", currentUser.Id);
        }
    }

    private void ToggleProfileMenu()
    {
        if (!IsMobile)
        {
            return;
        }

        showMobileProfile = !showMobileProfile;
    }

    private void CloseProfileMenu()
    {
        showMobileProfile = false;
    }

    private async Task LogoutAsync()
    {
        await BookingService.LogoutAsync();
        Navigation.NavigateTo("/", forceLoad: false);
    }

    private static string BuildAvatarStyle(UserModel user)
    {
        return $"--user-avatar-color: {user.AvatarColor}";
    }

    private static string GetUserInitial(UserModel user)
    {
        return string.IsNullOrWhiteSpace(user.Name)
            ? "?"
            : user.Name[..1].ToUpperInvariant();
    }

    public void Dispose()
    {
        BookingService.OnChange -= HandleBookingServiceChanged;
    }
}