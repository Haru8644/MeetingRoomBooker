{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=app.local.db"
  },
  "Database": {
    "ApplyMigrationsOnStartup": false,
    "EnsureCreatedOnStartup": true
  },
  "RoomConflictDetection": {
    "Enabled": false,
    "IntervalMinutes": 1,
    "LookbackMinutes": 15
  }
}